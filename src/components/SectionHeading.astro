---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props as Props;
---

<div class="max-w-3xl space-y-5">
  <p class="font-mono text-[0.7rem] uppercase tracking-[0.34em] text-signal">{eyebrow}</p>
  <h2 class="font-display text-3xl font-semibold tracking-[-0.045em] text-white sm:text-4xl lg:text-[2.85rem]">
    {title}
  </h2>
  {intro && <p class="max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">{intro}</p>}
</div>
