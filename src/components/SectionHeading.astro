---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props as Props;
---

<div class="max-w-3xl space-y-4">
  <p class="font-mono text-xs uppercase tracking-[0.28em] text-signal">{eyebrow}</p>
  <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">{title}</h2>
  {intro && <p class="text-base leading-7 text-slate-300 sm:text-lg">{intro}</p>}
</div>
