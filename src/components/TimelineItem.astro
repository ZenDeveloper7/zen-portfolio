---
interface Props {
  period: string;
  role: string;
  company: string;
  summary: string;
}

const { period, role, company, summary } = Astro.props as Props;
---

<div class="surface-panel grid gap-5 rounded-[1.5rem] p-6 md:grid-cols-[180px_1fr] md:items-start md:gap-8">
  <div class="flex items-center gap-3 font-mono text-[0.68rem] uppercase tracking-[0.28em] text-slate-500">
    <span class="h-2 w-2 rounded-full bg-signal/75"></span>
    <span>{period}</span>
  </div>
  <div>
    <h3 class="font-display text-2xl font-semibold tracking-[-0.035em] text-white">{role}</h3>
    <p class="mt-2 text-sm uppercase tracking-[0.18em] text-signal">{company}</p>
    <p class="mt-5 max-w-3xl text-sm leading-8 text-slate-300">{summary}</p>
  </div>
</div>
