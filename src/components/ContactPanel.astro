---
interface LinkItem {
  label: string;
  value: string;
}

interface Props {
  blurb: string;
  email: string;
  location: string;
  links: LinkItem[];
}

const { blurb, email, location, links } = Astro.props as Props;
---

<div class="surface-panel rounded-[1.9rem] p-8 shadow-glow sm:p-10">
  <p class="max-w-2xl text-base leading-8 text-slate-300">{blurb}</p>
  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    <div>
      <p class="font-mono text-[0.68rem] uppercase tracking-[0.3em] text-slate-500">Email</p>
      <a
        class="mt-3 inline-block font-display text-2xl tracking-[-0.03em] text-white transition duration-300 hover:text-signal"
        href={`mailto:${email}`}
      >
        {email}
      </a>
    </div>
    <div>
      <p class="font-mono text-[0.68rem] uppercase tracking-[0.3em] text-slate-500">Location</p>
      <p class="mt-3 text-lg leading-8 text-white">{location}</p>
    </div>
  </div>
  <div class="mt-10 flex flex-wrap gap-3">
    {links.map((link) => (
      <span class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-slate-200 transition duration-300 hover:border-signal/25 hover:text-white">
        {link.label}: {link.value}
      </span>
    ))}
  </div>
</div>
