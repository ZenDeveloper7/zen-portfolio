---
interface LinkItem {
  label: string;
  value: string;
}

interface Props {
  blurb: string;
  email: string;
  location: string;
  links: LinkItem[];
}

const { blurb, email, location, links } = Astro.props as Props;
---

<div class="rounded-[1.8rem] border border-white/10 bg-white/[0.03] p-8 shadow-glow">
  <p class="max-w-xl text-base leading-7 text-slate-300">{blurb}</p>
  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-slate-500">Email</p>
      <a class="mt-2 inline-block text-lg text-white transition hover:text-signal" href={`mailto:${email}`}>
        {email}
      </a>
    </div>
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-slate-500">Location</p>
      <p class="mt-2 text-lg text-white">{location}</p>
    </div>
  </div>
  <div class="mt-8 flex flex-wrap gap-3">
    {links.map((link) => (
      <span class="rounded-full border border-white/10 px-4 py-2 text-sm text-slate-200">
        {link.label}: {link.value}
      </span>
    ))}
  </div>
</div>
