---
interface Props {
  title: string;
  label: string;
  summary: string;
  stack: string[];
  outcome: string;
}

const { title, label, summary, stack, outcome } = Astro.props as Props;
---

<article class="group flex h-full flex-col rounded-[1.6rem] border border-white/10 bg-white/[0.03] p-6 shadow-glow transition duration-300 hover:-translate-y-1 hover:border-signal/40">
  <div class="mb-6 flex items-start justify-between gap-4">
    <div>
      <p class="mb-2 font-mono text-xs uppercase tracking-[0.25em] text-flare">{label}</p>
      <h3 class="text-2xl font-semibold tracking-tight text-white">{title}</h3>
    </div>
    <div class="hidden h-12 w-12 rounded-2xl border border-white/10 bg-white/[0.04] sm:block"></div>
  </div>
  <p class="text-sm leading-7 text-slate-300">{summary}</p>
  <div class="mt-6 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="rounded-full border border-white/10 px-3 py-1.5 font-mono text-xs text-slate-200">
        {item}
      </span>
    ))}
  </div>
  <p class="mt-6 border-t border-white/10 pt-6 text-sm leading-7 text-slate-400">{outcome}</p>
</article>
