---
interface Props {
  title: string;
  label: string;
  summary: string;
  stack: string[];
  outcome: string;
}

const { title, label, summary, stack, outcome } = Astro.props as Props;
---

<article class="group surface-panel relative flex h-full flex-col overflow-hidden rounded-[1.7rem] p-7 transition duration-500 hover:-translate-y-1 hover:border-signal/25 hover:shadow-glow">
  <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100">
    <div class="absolute inset-x-[-30%] top-0 h-px bg-gradient-to-r from-transparent via-signal/55 to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-signal/[0.07] to-transparent"></div>
  </div>
  <div class="mb-7 flex items-start justify-between gap-4">
    <div>
      <p class="mb-3 font-mono text-[0.68rem] uppercase tracking-[0.3em] text-flare">{label}</p>
      <h3 class="font-display text-[1.75rem] font-semibold tracking-[-0.04em] text-white">{title}</h3>
    </div>
    <div class="hidden h-12 w-12 rounded-2xl border border-white/10 bg-white/[0.04] sm:grid sm:place-items-center">
      <div class="h-2 w-2 rounded-full bg-signal/80 transition duration-500 group-hover:scale-125 group-hover:bg-signal"></div>
    </div>
  </div>
  <p class="text-[0.97rem] leading-8 text-slate-300">{summary}</p>
  <div class="mt-7 flex flex-wrap gap-2.5">
    {stack.map((item) => (
      <span class="rounded-full border border-white/10 bg-white/[0.025] px-3 py-1.5 font-mono text-[0.68rem] uppercase tracking-[0.18em] text-slate-200">
        {item}
      </span>
    ))}
  </div>
  <p class="mt-7 border-t border-white/10 pt-7 text-sm leading-7 text-slate-400">{outcome}</p>
</article>
