---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactPanel from "../components/ContactPanel.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StackPill from "../components/StackPill.astro";
import TimelineItem from "../components/TimelineItem.astro";
import { about, contact, experience, hero, projects, skills } from "../data/portfolio";
---

<BaseLayout>
  <main class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,_#05070b_0%,_#07101a_38%,_#05070b_100%)]"></div>
    <div class="absolute inset-0 -z-10 bg-grid bg-[length:56px_56px] opacity-[0.07]"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
    <div class="absolute left-[8%] top-20 -z-10 h-56 w-56 rounded-full bg-flare/10 blur-3xl animate-drift"></div>
    <div class="absolute right-[7%] top-[26rem] -z-10 h-72 w-72 rounded-full bg-signal/10 blur-3xl animate-drift"></div>

    <header class="mx-auto flex w-full max-w-proseplus items-center justify-between px-6 py-6 sm:px-8 lg:px-10">
      <a href="#" class="font-mono text-[0.8rem] uppercase tracking-[0.42em] text-white">SUHAS</a>
      <nav class="hidden items-center gap-7 text-sm text-slate-300 md:flex">
        <a href="#about" class="relative transition duration-300 hover:text-white after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-signal/75 after:transition after:duration-300 hover:after:scale-x-100">About</a>
        <a href="#projects" class="relative transition duration-300 hover:text-white after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-signal/75 after:transition after:duration-300 hover:after:scale-x-100">Projects</a>
        <a href="#stack" class="relative transition duration-300 hover:text-white after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-signal/75 after:transition after:duration-300 hover:after:scale-x-100">Stack</a>
        <a href="#experience" class="relative transition duration-300 hover:text-white after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-signal/75 after:transition after:duration-300 hover:after:scale-x-100">Experience</a>
        <a href="#contact" class="relative transition duration-300 hover:text-white after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-signal/75 after:transition after:duration-300 hover:after:scale-x-100">Contact</a>
      </nav>
    </header>

    <section class="mx-auto grid min-h-[calc(100vh-5rem)] max-w-proseplus gap-14 px-6 pb-28 pt-8 sm:px-8 lg:grid-cols-[minmax(0,1.15fr)_24rem] lg:px-10 lg:pb-36 lg:pt-14">
      <div class="flex flex-col justify-center">
        <div class="reveal is-visible" data-reveal data-reveal-delay="0">
          <p class="font-mono text-[0.72rem] uppercase tracking-[0.34em] text-signal">{hero.eyebrow}</p>
        </div>
        <h1
          class="reveal mt-6 max-w-5xl font-display text-[3.4rem] font-semibold leading-[0.92] tracking-[-0.07em] text-white sm:text-[4.5rem] lg:text-[6.1rem]"
          data-reveal
          data-reveal-delay="1"
        >
          {hero.title}
        </h1>
        <p
          class="reveal mt-8 max-w-2xl text-[1.05rem] leading-8 text-slate-300 sm:text-[1.18rem] sm:leading-9"
          data-reveal
          data-reveal-delay="2"
        >
          {hero.summary}
        </p>
        <div class="reveal mt-10 flex flex-wrap gap-4" data-reveal data-reveal-delay="3">
          <a
            href={hero.primaryCta.href}
            class="group relative overflow-hidden rounded-full border border-signal/40 bg-signal/10 px-6 py-3 text-sm font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:border-signal hover:bg-signal/15"
          >
            <span class="pointer-events-none absolute inset-y-0 left-0 w-16 -translate-x-[140%] bg-gradient-to-r from-transparent via-white/20 to-transparent opacity-0 transition duration-300 group-hover:animate-sheen group-hover:opacity-100"></span>
            {hero.primaryCta.label}
          </a>
          <a
            href={hero.secondaryCta.href}
            class="rounded-full border border-white/10 px-6 py-3 text-sm font-semibold text-slate-200 transition duration-300 hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/[0.035] hover:text-white"
          >
            {hero.secondaryCta.label}
          </a>
        </div>
        <div class="reveal mt-12 grid gap-4 text-sm text-slate-400 sm:grid-cols-3" data-reveal data-reveal-delay="3">
          {hero.metrics.map((metric) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.02] px-4 py-4 backdrop-blur-sm">
              <p class="font-mono text-[0.66rem] uppercase tracking-[0.28em] text-slate-500">{metric.label}</p>
              <p class="mt-2 font-display text-xl tracking-[-0.04em] text-white">{metric.value}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="reveal relative lg:pt-10" data-reveal data-reveal-delay="2">
        <div class="surface-panel rounded-[2rem] p-6 shadow-glow">
          <div class="rounded-[1.5rem] border border-white/10 bg-panel px-6 py-7">
            <div class="flex items-center justify-between">
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.3em] text-slate-500">System snapshot</p>
              <span class="h-2.5 w-2.5 rounded-full bg-signal animate-pulseLine"></span>
            </div>
            <div class="mt-7 space-y-6">
              {hero.metrics.map((metric) => (
                <div class="hairline pb-5 last:pb-0 last:after:hidden">
                  <p class="font-mono text-[0.66rem] uppercase tracking-[0.26em] text-slate-500">{metric.label}</p>
                  <p class="mt-2 font-display text-[1.85rem] font-semibold tracking-[-0.05em] text-white">{metric.value}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-5 rounded-[1.5rem] border border-white/10 bg-white/[0.02] p-6">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.3em] text-slate-500">Current direction</p>
            <p class="mt-4 text-sm leading-8 text-slate-300">
              Shipping modern Android products with strong Kotlin and Jetpack Compose depth, plus enough Flutter and backend experience to take features from UI to integration without handoff friction.
            </p>
          </div>
        </div>
      </aside>
    </section>

    <section id="about" class="section-shell mx-auto max-w-proseplus px-6 py-20 sm:px-8 lg:px-10 lg:py-24">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="About"
          title="Android depth, product ownership, and a strong bias toward shipping work that stays maintainable."
        />
      </div>
      <div class="mt-12 grid gap-8 lg:grid-cols-[1fr_0.82fr]">
        <div class="reveal space-y-7 text-[1.02rem] leading-8 text-slate-300" data-reveal data-reveal-delay="1">
          {about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="reveal surface-panel rounded-[1.9rem] p-8 sm:p-9" data-reveal data-reveal-delay="2">
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.34em] text-ember">Working style</p>
          <ul class="mt-7 space-y-4 text-sm leading-8 text-slate-300">
            <li>Prefer ownership-heavy roles with clear customer impact.</li>
            <li>Modernize carefully: architecture, UI, and delivery quality should move together.</li>
            <li>Ship complete features through collaboration across design, product, and engineering.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="projects" class="section-shell mx-auto max-w-proseplus px-6 py-20 sm:px-8 lg:px-10 lg:py-24">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Selected Projects"
          title="Selected work across mobile engineering, developer tooling, and backend-adjacent builds."
          intro="Featured projects are pulled from public GitHub work and ordered to better reflect Android depth, tooling instincts, and product range."
        />
      </div>
      <div class="mt-12 grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {projects.map((project, index) => (
          <div class="reveal" data-reveal data-reveal-delay={String(index % 3)}>
            <ProjectCard {...project} />
          </div>
        ))}
      </div>
    </section>

    <section id="stack" class="section-shell mx-auto max-w-proseplus px-6 py-20 sm:px-8 lg:px-10 lg:py-24">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Skills / Stack"
          title="Core strengths across Android, Flutter, architecture, and delivery."
        />
      </div>
      <div class="reveal mt-12 flex flex-wrap gap-3" data-reveal data-reveal-delay="1">
        {skills.map((skill) => <StackPill label={skill} />)}
      </div>
    </section>

    <section id="experience" class="section-shell mx-auto max-w-proseplus px-6 py-20 sm:px-8 lg:px-10 lg:py-24">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Experience"
          title="Mobile product experience across Android modernization, Flutter delivery, and white-labeled app platforms."
        />
      </div>
      <div class="mt-12 space-y-5">
        {experience.map((item, index) => (
          <div class="reveal" data-reveal data-reveal-delay={String(index % 3)}>
            <TimelineItem {...item} />
          </div>
        ))}
      </div>
    </section>

    <section id="contact" class="section-shell mx-auto max-w-proseplus px-6 py-20 pb-28 sm:px-8 lg:px-10 lg:py-24 lg:pb-36">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Contact"
          title="Where to find me."
        />
      </div>
      <div class="reveal mt-12" data-reveal data-reveal-delay="1">
        <ContactPanel {...contact} />
      </div>
    </section>
  </main>
</BaseLayout>
